#!/usr/bin/env bash

## Description: Interactive migration menu for WP Migrate Pro
## Usage: migration
## Example: "ddev migration"

set -euo pipefail

# Configuration
CONNECTIONS_FILE=".conf/migrations/connections.json"

# Ensure connections file exists
ensure_connections_file() {
  if [ ! -f "$CONNECTIONS_FILE" ]; then
    mkdir -p "$(dirname "$CONNECTIONS_FILE")"
    echo "{}" > "$CONNECTIONS_FILE"
    echo "Created new connections file: $CONNECTIONS_FILE"
  fi
}

# Strip any .gitignore rule that would prevent the connections file from
# being tracked. Connections are meant to be shared with the team via git.
check_connections_tracked() {
  command -v git >/dev/null 2>&1 || return 0
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 0

  # Loop in case multiple rules match — git only reports the last one applied.
  while git check-ignore -q "$CONNECTIONS_FILE" 2>/dev/null; do
    local source_info source_file rest source_line removed
    source_info=$(git check-ignore -v "$CONNECTIONS_FILE" 2>/dev/null || true)
    source_file="${source_info%%:*}"
    rest="${source_info#*:}"
    source_line="${rest%%:*}"

    if [ ! -f "$source_file" ] || ! [[ "$source_line" =~ ^[0-9]+$ ]]; then
      echo ""
      echo "⚠️  $CONNECTIONS_FILE is ignored by git but the rule isn't in a"
      echo "   local .gitignore I can edit. Source: $source_info"
      echo ""
      break
    fi

    removed=$(sed -n "${source_line}p" "$source_file")
    sed -i "${source_line}d" "$source_file"
    echo "Removed ignore rule from $source_file (line $source_line): $removed"
  done
}

# Check if gum is available, fallback to basic prompts
has_gum() {
  command -v gum >/dev/null 2>&1
}

# Safe prompt function with fallback. On cancel (Esc), returns empty string
# without aborting under `set -e`.
prompt_input() {
  local prompt_text="$1"
  local placeholder="${2:-}"
  local result=""

  if has_gum; then
    local gum_args=(--prompt "$prompt_text ")
    if [ -n "$placeholder" ]; then
      gum_args+=(--placeholder "$placeholder")
    fi
    if result=$(gum input "${gum_args[@]}"); then
      # User submitted; apply placeholder as default when empty
      if [ -z "$result" ] && [ -n "$placeholder" ]; then
        result="$placeholder"
      fi
    else
      # User cancelled — leave result empty so callers can detect it
      result=""
    fi
  else
    read -p "$prompt_text " result
    if [ -z "$result" ] && [ -n "$placeholder" ]; then
      result="$placeholder"
    fi
  fi

  echo "$result"
}

# Safe confirm function with fallback
prompt_confirm() {
  local prompt_text="$1"

  if has_gum; then
    gum confirm "$prompt_text"
  else
    read -p "$prompt_text (y/N) " -n 1 -r
    echo
    [[ $REPLY =~ ^[Yy]$ ]]
  fi
}

# Safe choose function with fallback. On cancel (Esc), prints nothing and
# returns success so callers can treat empty output as "back / cancelled"
# without tripping `set -e`.
prompt_choose() {
  local prompt_text="$1"
  shift
  local options=("$@")

  if has_gum; then
    gum choose --header "$prompt_text" "${options[@]}" || true
  else
    echo "$prompt_text" >&2
    local i=1
    for opt in "${options[@]}"; do
      echo "$i) $opt" >&2
      ((i++))
    done
    read -p "Enter choice (1-${#options[@]}): " choice
    if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#options[@]}" ]; then
      echo "${options[$((choice-1))]}"
    fi
  fi
}

# Parse combined connection string (format: "https://example.com secret-key")
parse_connection_string() {
  local input="$1"
  local url=""
  local secret=""

  # Try to parse as "URL SECRET" format
  if [[ "$input" =~ ^(https?://[^[:space:]]+)[[:space:]]+([^[:space:]]+)$ ]]; then
    url="${BASH_REMATCH[1]}"
    secret="${BASH_REMATCH[2]}"
  else
    # Not a combined format, return empty
    return 1
  fi

  echo "$url"
  echo "$secret"
}

# Add a new connection
add_connection() {
  ensure_connections_file
  check_connections_tracked

  echo ""
  echo "=================================================="
  echo "Add New Connection"
  echo "=================================================="
  echo ""
  echo "You can paste the combined connection string from WP Migrate Pro"
  echo "(format: 'https://example.com secret-key') or enter details separately."
  echo ""

  # Get connection string
  connection_input=$(prompt_input "Connection string or URL:" "https://example.com secret-key")

  if [ -z "$connection_input" ]; then
    echo "Cancelled."
    return
  fi

  # Try to parse combined format
  local url=""
  local secret=""
  if parsed=$(parse_connection_string "$connection_input" 2>&1); then
    url=$(echo "$parsed" | sed -n '1p')
    secret=$(echo "$parsed" | sed -n '2p')
    echo "✓ Parsed combined connection string"
  else
    # Single field, assume it's just the URL
    url="$connection_input"
    secret=$(prompt_input "Secret key:" "your-secret-key-here")
  fi

  if [ -z "$url" ] || [ -z "$secret" ]; then
    echo "Error: URL and secret key are required."
    return 1
  fi

  # Get branch name
  branch=$(prompt_input "Branch name:" "develop")
  if [ -z "$branch" ]; then
    echo "Error: Branch name is required."
    return 1
  fi

  # Check if connection already exists
  if jq -e ".\"$branch\"" "$CONNECTIONS_FILE" >/dev/null 2>&1; then
    echo ""
    if ! prompt_confirm "Connection '$branch' already exists. Overwrite?"; then
      echo "Cancelled."
      return
    fi
  fi

  # Build JSON object. Label defaults to branch; description is omitted by
  # default and can be added via hand-edit of connections.json.
  local connection_obj
  connection_obj=$(jq -n \
    --arg url "$url" \
    --arg secret "$secret" \
    --arg lbl "$branch" \
    '{url: ($url), secret: ($secret), label: ($lbl)}')

  # Update connections file
  jq ".\"$branch\" = $connection_obj" "$CONNECTIONS_FILE" > "${CONNECTIONS_FILE}.tmp"
  mv "${CONNECTIONS_FILE}.tmp" "$CONNECTIONS_FILE"

  echo ""
  echo "✓ Connection '$branch' saved successfully!"
  echo ""
}

# List all connections
list_connections() {
  ensure_connections_file

  echo ""
  echo "=================================================="
  echo "Configured Connections"
  echo "=================================================="
  echo ""

  if [ "$(jq 'length' "$CONNECTIONS_FILE")" -eq 0 ]; then
    echo "No connections configured yet."
    echo "Use 'Add Connection' to create one."
    echo ""
    return
  fi

  jq -r 'to_entries[] | "  [\(.key)] \(.value.label // .key)\n    URL: \(.value.url)" + (if .value.description then "\n    Description: \(.value.description)" else "" end) + "\n"' "$CONNECTIONS_FILE"

  echo ""
}

# Pull from a connection. If $1 is provided, skip the picker; otherwise show
# the legacy picker as a fallback.
pull_connection() {
  ensure_connections_file
  local branch="${1:-}"

  if [ -z "$branch" ]; then
    if [ "$(jq 'length' "$CONNECTIONS_FILE")" -eq 0 ]; then
      echo ""
      echo "No connections configured yet."
      echo "Please add a connection first."
      echo ""
      return
    fi

    mapfile -t labels < <(jq -r 'to_entries[] | "\(.key): \(.value.label // .key)"' "$CONNECTIONS_FILE")
    selected=$(prompt_choose "Select connection:" "${labels[@]}")
    if [ -z "$selected" ]; then
      echo "Cancelled."
      return
    fi
    branch=$(echo "$selected" | cut -d: -f1)
  fi

  echo ""
  echo "=================================================="
  echo "Pull from Remote"
  echo "=================================================="
  echo ""

  # Choose media handling strategy
  echo ""
  echo "Note: For faster media sync via rsync, use 'make pull-staging' or 'make pull-production'"
  echo ""
  media_strategy=$(prompt_choose "How should media be handled?" \
    "Include media (synced via WP Migrate Pro)" \
    "Skip media (database only)" \
    "← Back to main menu")

  local migration_result=0
  case "$media_strategy" in
    "Include"*)
      bash .ddev/commands/web/run-migration "$branch"
      migration_result=$?
      ;;
    "Skip"*)
      bash .ddev/commands/web/run-migration "$branch" --skip-media
      migration_result=$?
      ;;
    "←"*|"")
      return
      ;;
    *)
      echo "Invalid selection"
      return 1
      ;;
  esac

  if [ $migration_result -eq 0 ]; then
    echo ""
    echo "✓ Migration completed. Exiting..."
    exit 0
  else
    echo ""
    echo "✗ Migration failed."
    echo ""
    echo "Press Enter to return to menu..."
    read
    return 1
  fi
}

# Push to a connection
push_connection() {
  ensure_connections_file

  # Check if any connections exist
  if [ "$(jq 'length' "$CONNECTIONS_FILE")" -eq 0 ]; then
    echo ""
    echo "No connections configured yet."
    echo "Please add a connection first."
    echo ""
    return
  fi

  echo ""
  echo "=================================================="
  echo "Push to Remote"
  echo "=================================================="
  echo ""

  # Get list of connections (excluding production)
  mapfile -t branches < <(jq -r 'keys[] | select(. != "master" and . != "production")' "$CONNECTIONS_FILE")

  if [ ${#branches[@]} -eq 0 ]; then
    echo "No non-production connections available for push."
    echo "Push to production is disabled for safety."
    echo ""
    return
  fi

  mapfile -t labels < <(jq -r 'to_entries[] | select(.key != "master" and .key != "production") | "\(.key): \(.value.label // .key)"' "$CONNECTIONS_FILE")
  labels+=("← Back to main menu")

  # Choose connection
  selected=$(prompt_choose "Select connection:" "${labels[@]}")
  if [ -z "$selected" ] || [[ "$selected" == "←"* ]]; then
    return
  fi

  # Extract branch from selection
  branch=$(echo "$selected" | cut -d: -f1)

  echo ""
  if ! prompt_confirm "⚠️  This will OVERWRITE the '$branch' remote database. Continue?"; then
    echo "Cancelled. No changes made."
    return
  fi

  # Get connection details
  REMOTE_URL=$(jq -r ".\"$branch\".url" "$CONNECTIONS_FILE")
  SECRET_KEY=$(jq -r ".\"$branch\".secret" "$CONNECTIONS_FILE")

  # Execute push
  echo ""
  echo "Pushing database..."

  if wp migrate push "$REMOTE_URL" "$SECRET_KEY" --url=${DDEV_PRIMARY_URL}; then
    echo ""
    echo "✓ Database pushed successfully!"
    echo ""
    echo "✓ Push completed. Exiting..."
    exit 0
  else
    echo ""
    echo "✗ Push failed."
    echo ""
    echo "Press Enter to return to menu..."
    read
    return 1
  fi
}

# Ensure wp-migrate-db-pro is installed and active; the `wp migrate` subcommand
# is only registered when the plugin is active. Run before the menu to fail
# fast rather than midway through an interactive flow.
ensure_migrate_plugin_ready() {
  if ! wp plugin is-installed wp-migrate-db-pro --url=${DDEV_PRIMARY_URL} >/dev/null 2>&1; then
    echo ""
    echo "✗ Error: wp-migrate-db-pro is not installed."
    echo ""
    echo "  Run 'make' or 'ddev composer install' from the project root to install"
    echo "  Composer dependencies, then try again."
    echo ""
    exit 1
  fi
  if ! wp plugin is-active wp-migrate-db-pro --url=${DDEV_PRIMARY_URL} >/dev/null 2>&1; then
    echo "Activating wp-migrate-db-pro plugin..."
    wp plugin activate wp-migrate-db-pro --url=${DDEV_PRIMARY_URL} >/dev/null
  fi
}

# Main menu loop. Pull targets are listed directly so the common case is one
# selection instead of two; push stays nested under a submenu.
main_menu() {
  ensure_connections_file
  ensure_migrate_plugin_ready

  while true; do
    clear
    echo "=================================================="
    echo "WP Migrate Pro - Migration Management"
    echo "=================================================="
    echo ""

    local -a menu=()
    local -a actions=()

    while IFS=$'\t' read -r key label; do
      [ -z "$key" ] && continue
      menu+=("Pull from $label")
      actions+=("pull"$'\t'"$key")
    done < <(jq -r 'to_entries[] | "\(.key)\t\(.value.label // .key)"' "$CONNECTIONS_FILE")

    local non_prod_count
    non_prod_count=$(jq '[to_entries[] | select(.key != "master" and .key != "production")] | length' "$CONNECTIONS_FILE")
    if [ "$non_prod_count" -gt 0 ]; then
      menu+=("Push to remote ›")
      actions+=("push"$'\t')
    fi

    menu+=("Add connection")
    actions+=("add"$'\t')
    menu+=("List connections")
    actions+=("list"$'\t')
    menu+=("Exit")
    actions+=("exit"$'\t')

    action=$(prompt_choose "What would you like to do?" "${menu[@]}")

    local idx=-1
    for i in "${!menu[@]}"; do
      if [ "${menu[$i]}" = "$action" ]; then
        idx=$i
        break
      fi
    done
    if [ "$idx" -lt 0 ]; then
      echo "Invalid selection"
      sleep 1
      continue
    fi

    local cmd="${actions[$idx]%%$'\t'*}"
    local branch="${actions[$idx]#*$'\t'}"

    case "$cmd" in
      pull) pull_connection "$branch" ;;
      push) push_connection ;;
      add)  add_connection ;;
      list) list_connections; read -p "Press Enter to continue..." ;;
      exit) echo ""; echo "Goodbye!"; exit 0 ;;
    esac
  done
}

# Run main menu
main_menu
